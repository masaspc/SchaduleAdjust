@model BookingViewModel
@{
    ViewData["Title"] = "この調整は終了しました";
    Layout = "~/Views/Booking/_BookingLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm text-center">
            <div class="card-body p-5">
                <div class="mb-4">
                    <i class="bi bi-clock-history text-warning" style="font-size: 4rem;"></i>
                </div>
                <h2 class="card-title mb-3">この日程調整は終了しました</h2>
                <p class="text-muted">
                    「@Model.Title」の日程調整は既に終了しているか、回答期限が過ぎています。
                </p>
                <p class="text-muted">
                    主催者にお問い合わせください。
                </p>
            </div>
        </div>
    </div>
</div>
